{
  "realm": "n2-users",
  "enabled": true,
  "displayName": "n2 Users Realm",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "name": "declarative-user-profile",
        "providerId": "declarative-user-profile",
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"email\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"tenant_name\",\"displayName\":\"Tenant Name\",\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"min\":1,\"max\":128}}}]}"
          ]
        }
      }
    ]
  },
  "roles": {
    "realm": [
      {
        "name": "tenant-admin"
      },
      {
        "name": "editor"
      },
      {
        "name": "viewer"
      }
    ]
  },
  "clientScopes": [
    {
      "name": "n2-users-access",
      "description": "Application access token claims for n2-users",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "subject",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "id",
            "claim.name": "sub",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "tenant_name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_name",
            "claim.name": "tenant_name",
            "jsonType.label": "String",
            "multivalued": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "authz_version",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "authz_version",
            "claim.name": "authz_version",
            "jsonType.label": "int",
            "multivalued": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm_roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "n2-users-frontend",
      "name": "n2 Users Frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8080/*",
        "http://127.0.0.1:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://127.0.0.1:8080"
      ],
      "defaultClientScopes": [
        "n2-users-access"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "id": "51000000-0000-0000-0000-000000000001",
      "username": "admin@example.com",
      "email": "admin@example.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "Developer",
      "attributes": {
        "tenant_name": [
          "Development Tenant"
        ],
        "authz_version": [
          "1"
        ]
      },
      "realmRoles": [
        "tenant-admin"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "Password123!",
          "temporary": false
        }
      ]
    },
    {
      "id": "51000000-0000-0000-0000-000000000002",
      "username": "editor@example.com",
      "email": "editor@example.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Editor",
      "lastName": "Developer",
      "attributes": {
        "tenant_name": [
          "Development Tenant"
        ],
        "authz_version": [
          "1"
        ]
      },
      "realmRoles": [
        "editor"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "Password123!",
          "temporary": false
        }
      ]
    },
    {
      "id": "51000000-0000-0000-0000-000000000003",
      "username": "viewer@example.com",
      "email": "viewer@example.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Viewer",
      "lastName": "Developer",
      "attributes": {
        "tenant_name": [
          "Development Tenant"
        ],
        "authz_version": [
          "1"
        ]
      },
      "realmRoles": [
        "viewer"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "Password123!",
          "temporary": false
        }
      ]
    }
  ]
}
